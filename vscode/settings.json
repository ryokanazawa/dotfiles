{
    "window.zoomLevel": 0.4,
    "editor.mouseWheelZoom": false,
    "editor.insertSpaces": false,
    "editor.tabSize": 4,
    "editor.useTabStops": true,
    "editor.detectIndentation": false,
    "files.insertFinalNewline": true,
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.fontFamily": "Inconsolata-dz for Powerline",
    "editor.formatOnSaveTimeout": 5000,
    "ruby.lint": {
        "rubocop": true
    },
    "ruby.format": "rubocop",
    "[ruby]": {
        "editor.formatOnSave": true
    },
    "python.pythonPath": "/usr/local/bin/python3",
    "python.linting.pylintEnabled": true,
    "python.linting.enabled": true,
    "python.linting.lintOnSave": true,
    "python.formatting.autopep8Path": "autopep8",
    "[python]": {
        "editor.formatOnSave": true
    },
    "diffEditor.renderSideBySide": false,
    "lldb.library": "/Library/Developer/CommandLineTools/Library/PrivateFrameworks/LLDB.framework/Versions/A/LLDB",
	"lldb.launch.expressions": "native",
    "git.autofetch": true,
    "debug.disassemblyView.showSourceCode": false,
    "workbench.editor.editorActionsLocation": "hidden",
    "explorer.confirmDelete": false,
    "[markdown]": {
		"editor.fontFamily": "'SF Pro Display', serif",
        "editor.lineHeight": 24,
        "editor.renderLineHighlight": "none",
        "editor.lineNumbers": "on",
        "files.autoSave": "afterDelay",
        "editor.occurrencesHighlight": "off"
    },
	"window.commandCenter": false,
	"workbench.navigationControl.enabled": false,
    "editor.scrollBeyondLastLine": false,
    "explorer.confirmDragAndDrop": false,
    "lldb.suppressUpdateNotifications": true,
	"workbench.editor.enablePreviewFromQuickOpen": true,
	"editor.fontFamily": "'Guguru Sans Code 35'",
	"terminal.integrated.defaultProfile.osx": "zsh",
	"editor.fontSize": 13,
	"workbench.colorTheme": "Gruvbox Dark Medium",
	"claudeCode.selectedModel": "default",
	"explorer.sortOrder": "modified",
	"editor.defaultFormatter": "vscode.markdown-language-features",
	"workbench.secondarySideBar.defaultVisibility": "hidden",
	"claudeCode.preferredLocation": "sidebar"
}
