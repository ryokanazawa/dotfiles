{
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "mcp__pencil",
      "Bash(xcodebuild -project Swan2.xcodeproj -scheme Swan2 -destination 'platform=iOS Simulator,name=iPhone 17' -quiet build)",
      "Bash(xcodebuild -project Swan2.xcodeproj -scheme Swan2 -destination 'platform=iOS Simulator,name=iPhone 17' -quiet test)",
      "Bash(git commit -m ' *)",
      "Bash(xcodebuild -project Swan2.xcodeproj -scheme Swan2 -destination 'platform=iOS Simulator,name=iPhone 17' test)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(xcodebuild -scheme Brushpass-Debug -configuration Debug -destination 'platform=macOS' build)",
      "Bash(xcodebuild -list)",
      "Bash(xcodebuild -scheme Brushpass -configuration Debug -destination 'platform=macOS' build)",
      "Bash(xcodebuild -scheme Brushpass -configuration Debug -destination 'platform=macOS' test -only-testing:BrushpassTests)",
      "Bash(git stash *)",
      "Bash(xcodebuild -scheme Brushpass -configuration Debug -destination 'platform=macOS' test -only-testing:BrushpassTests/WindowManagerSessionCommandTests/closeWindowCommandTargetingOwnProcessUsesNSWindowCloseAndBypassesAX)",
      "Bash(xcodebuild -scheme Brushpass -configuration Debug -destination 'platform=macOS' test -only-testing:BrushpassTests/WindowManagerSessionCommandTests)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-8",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/Developer/dotfiles/claude/hooks/session-title.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "effortLevel": "medium",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "light-daltonized",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
