{
  "env": {
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "mcp__pencil",
      "Bash(xcodebuild -project Swan2.xcodeproj -scheme Swan2 -destination 'platform=iOS Simulator,name=iPhone 17' -quiet build)",
      "Bash(xcodebuild -project Swan2.xcodeproj -scheme Swan2 -destination 'platform=iOS Simulator,name=iPhone 17' -quiet test)",
      "Bash(git commit -m ' *)",
      "Bash(xcodebuild -project Swan2.xcodeproj -scheme Swan2 -destination 'platform=iOS Simulator,name=iPhone 17' test)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.cwd' | { read -r d; printf '\\033]2;Claude · %s\\007' \"$(basename \"$d\")\" > /dev/tty 2>/dev/null; } || true"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
